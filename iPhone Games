<!DOCTYPE html>
<html>
<head>
  <title>Moo</title>
  <style>
    body {
      margin: 0;
      height: 100vh;
      background: #fff3d6;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      font-family: Arial, sans-serif;
      text-align: center;
      overflow: hidden;
    }

    h1 {
      font-size: 48px;
    }

    .cow {
      font-size: 90px;
      animation: bounce 0.7s infinite alternate;
    }

    button {
      font-size: 24px;
      padding: 15px 25px;
      border-radius: 12px;
      border: none;
      background: black;
      color: white;
    }

    @keyframes bounce {
      from { transform: scale(1); }
      to { transform: scale(1.2) rotate(5deg); }
    }
  </style>
</head>
<body>
  <div class="cow">🐮</div>
  <h1>You have been MOO’d</h1>
  <button onclick="moo()">Tap to continue</button>

  <audio id="mooSound" src="https://www.soundjay.com/animal/cow-moo1.mp3"></audio>

  <script>
    function moo() {
      document.getElementById("mooSound").play();
      document.body.innerHTML = `
        <div class="cow">🐮🐮🐮</div>
        <h1>MOOOOOOOO!</h1>
        <p>Relax, it’s just a cow prank 😂</p>
      `;

      if (navigator.vibrate) {
        navigator.vibrate([200, 100, 200]);
      }
    }
  </script>
</body>
</html>
